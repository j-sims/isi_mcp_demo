# isi_mcp application configuration (non-secret defaults)
# To enable OAuth: change AUTH_ENABLED to true, then restart with ./start.sh
# (which will prompt for Keycloak passwords).

VAULT_FILE=/app/vault/vault.yml

AUTH_ENABLED=false
KEYCLOAK_URL=http://keycloak:8080/auth
KEYCLOAK_REALM=powerscale
MCP_PUBLIC_URL=https://localhost

# Audit log settings
MAX_AUDIT_LOGFILE_SIZE=10485760
MAX_AUDIT_LOGFILE_COUNT=10
